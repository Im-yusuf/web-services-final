// Prisma schema for the EcoNest database.
// Maps to PostgreSQL tables with explicit @@map names.
// Includes models for users, sessions, property sales, saved listings,
// market reports, and user preferences.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Registered user — owns sessions, saved listings, and preferences
model User {
  id           String           @id @default(uuid())
  email        String           @unique
  passwordHash String           @map("password_hash")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  savedListings SavedListing[]
  preferences  UserPreference?
  sessions     Session[]

  @@map("users")
}

// Session-based auth tokens — each row represents an active login session
model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

// Individual property sale from the HM Land Registry Price Paid dataset
model PropertySale {
  id             String         @id @default(uuid())
  transactionId  String         @unique @map("transaction_id")
  price          Int
  transferDate   DateTime       @map("transfer_date")
  postcode       String
  propertyType   String         @map("property_type")
  newBuild       Boolean        @default(false) @map("new_build")
  tenure         String
  street         String
  townCity       String         @map("town_city")
  district       String
  county         String
  createdAt      DateTime       @default(now()) @map("created_at")
  savedListings  SavedListing[]

  @@index([postcode])
  @@index([townCity])
  @@index([district])
  @@index([county])
  @@index([transferDate])
  @@index([propertyType])
  @@index([price])
  @@map("property_sales")
}

// Many-to-many link between users and properties they have bookmarked
model SavedListing {
  id         String       @id @default(uuid())
  userId     String       @map("user_id")
  propertyId String       @map("property_id")
  notes      String?
  createdAt  DateTime     @default(now()) @map("created_at")
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   PropertySale @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("saved_listings")
}

// Cached market report summaries (can be pre-computed for performance)
model MarketReport {
  id          String   @id @default(uuid())
  region      String
  avgPrice    Float    @map("avg_price")
  priceGrowth Float    @map("price_growth")
  totalSales  Int      @default(0) @map("total_sales")
  reportDate  DateTime @map("report_date")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([region])
  @@index([reportDate])
  @@map("market_reports")
}

// User saved search/filter preferences for personalisation
model UserPreference {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  favoriteRegions String[] @map("favorite_regions")
  budgetMin      Int?     @map("budget_min")
  budgetMax      Int?     @map("budget_max")
  propertyTypes  String[] @map("property_types")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}
